# Telegram bot token from BotFather
BOT_TOKEN=replace_me

# Runtime mode: polling does not require a domain or TLS
BOT_RUN_MODE=polling

# Optional future webhook base URL, for example https://example.com
# Leave empty while BOT_RUN_MODE=polling
WEBHOOK_BASE_URL=

REDIS_URL=redis://redis:6379/0
VERIFY_TIMEOUT_SECONDS=180

# Spam action mode: delete or notify_admin
ACTION_MODE=notify_admin

ADMIN_USERNAME=@admin
ADMIN_ID=

# LLM provider settings: real credentials must never be committed
LLM_API_KEY=replace_me
LLM_BASE_URL=https://api.example.com/v1
LLM_MODEL=replace_me
LLM_TIMEOUT_SECONDS=8

LOG_LEVEL=INFO
LOG_FILE=/app/logs/spam.log
